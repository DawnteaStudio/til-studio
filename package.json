{
  "name": "til-studio",
  "version": "0.1.0",
  "private": true,
  "main": "desktop/main.mjs",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:desktop": "next build && node scripts/prepare-standalone.mjs",
    "start": "next start",
    "desktop": "electron desktop/main.mjs",
    "desktop:app": "node scripts/create-menu-app.mjs",
    "dist:mac": "npm run build:desktop && electron-builder --mac",
    "dist:mac:dir": "npm run build:desktop && electron-builder --mac dir",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@octokit/app": "^16.1.2",
    "@octokit/rest": "^22.0.1",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "next": "16.2.6",
    "openai": "^6.39.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.7"
  },
  "build": {
    "appId": "studio.til.desktop",
    "productName": "TIL Studio",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "asar": true,
    "files": [
      "desktop/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "next",
        "filter": [
          "**/*",
          "!node_modules/**/*"
        ]
      },
      {
        "from": ".next/standalone/node_modules",
        "to": "next/node_modules",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "DawnteaStudio",
        "repo": "til-studio"
      }
    ]
  }
}
